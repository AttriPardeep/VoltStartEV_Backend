{
  "name": "voltstartev-backend",
  "version": "1.0.0",
  "description": "VoltStartEV OCPP 1.6 Backend with SteVe Integration",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.cjs",
    "test:integration": "jest --config jest.config.cjs --testPathPattern=integration",
    "test:watch": "jest --config jest.config.cjs --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:migrate:steve": "tsx scripts/verify-steve-schema.ts",
    "db:seed:readonly": "tsx scripts/create-readonly-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.7.4",
    "validator": "^13.15.26",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
